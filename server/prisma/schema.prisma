generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Site {
  id             String   @id @default(uuid())
  name           String   @unique
  nameCn         String
  nameEn         String?
  domain         String?
  logo           String?
  primaryColor   String   @default("#1a3a6b")
  secondaryColor String?
  phone          String?
  email          String?
  address        String?
  icp            String?
  police         String?
  description    String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users         SiteUser[]
  departments   Department[]
  nodes         Node[]
  articles      Article[]
  media         Media[]
  banners       Banner[]
  friendLinks   FriendLink[]
  leaders       Leader[]
  teachers      Teacher[]
  navItems      NavItem[]
  quickLinks    QuickLink[]
  siteConfig    SiteConfig?
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("sites")
}

model User {
  id          String    @id @default(uuid())
  username    String    @unique
  password    String
  email       String?   @unique
  phone       String?
  realName    String?
  avatar      String?
  isActive    Boolean   @default(true)
  isGlobal    Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  siteUsers     SiteUser[]
  articles      Article[]
  media         Media[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  siteUsers       SiteUser[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  resource    String?
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  nodePermissions NodePermission[]

  @@unique([module, action, resource])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model SiteUser {
  id        String   @id @default(uuid())
  siteId    String
  userId    String
  roleId    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([siteId, userId])
  @@map("site_users")
}

model Department {
  id          String   @id @default(uuid())
  siteId      String
  parentId    String?
  name        String
  code        String?
  sort        Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site     Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children Department[] @relation("DeptTree")

  @@map("departments")
}

model Node {
  id          String   @id @default(uuid())
  siteId      String
  parentId    String?
  name        String
  code        String?
  type        String   @default("COLUMN")
  sort        Int      @default(0)
  isVisible   Boolean  @default(true)
  template    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site        Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent      Node?            @relation("NodeTree", fields: [parentId], references: [id])
  children    Node[]           @relation("NodeTree")
  articles    Article[]
  permissions NodePermission[]

  @@map("nodes")
}

model NodePermission {
  id           String   @id @default(uuid())
  nodeId       String
  permissionId String
  createdAt    DateTime @default(now())

  node       Node       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([nodeId, permissionId])
  @@map("node_permissions")
}

model Article {
  id          String    @id @default(uuid())
  siteId      String
  nodeId      String?
  authorId    String?
  title       String
  content     String
  summary     String?
  coverImage  String?
  status      String    @default("DRAFT")
  sort        Int       @default(0)
  viewCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site   Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  node   Node? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@map("articles")
}

model Media {
  id           String   @id @default(uuid())
  siteId       String
  uploaderId   String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  type         String   @default("IMAGE")
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site     Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@map("media")
}

model Banner {
  id        String   @id @default(uuid())
  siteId    String
  title     String
  subtitle  String?  @default("")
  imageUrl  String
  linkUrl   String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("banners")
}

model FriendLink {
  id        String   @id @default(uuid())
  siteId    String
  name      String
  url       String
  logo      String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("friend_links")
}

model Leader {
  id        String   @id @default(uuid())
  siteId    String
  name      String
  position  String
  photo     String?
  bio       String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("leaders")
}

model Teacher {
  id        String   @id @default(uuid())
  siteId    String
  name      String
  title     String?
  subject   String?
  years     Int?
  photo     String?
  bio       String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model NavItem {
  id        String   @id @default(uuid())
  siteId    String
  parentId  String?
  name      String
  url       String?
  icon      String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   NavItem?  @relation("NavTree", fields: [parentId], references: [id])
  children NavItem[] @relation("NavTree")

  @@map("nav_items")
}

model QuickLink {
  id        String   @id @default(uuid())
  siteId    String
  name      String
  url       String
  color     String?  @default("#3b82f6")
  icon      String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("quick_links")
}

model SiteConfig {
  id        String   @id @default(uuid())
  siteId    String   @unique
  config    String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_configs")
}

model AuditLog {
  id         String   @id @default(uuid())
  siteId     String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  detail     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  siteId    String?
  userId    String
  title     String
  content   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RecycleBin {
  id           String   @id @default(uuid())
  siteId       String
  resourceType String
  resourceId   String
  data         String
  deletedBy    String?
  deletedAt    DateTime @default(now())

  @@map("recycle_bin")
}
