# 环境变量示例文件
# 复制此文件为 .env 并填写实际值

# 数据库 URL（Render 会自动注入，本地开发用 sqlite://./dev/CMS.db）
DATABASE_URL="postgresql://user:password@localhost:5432/cmds?schema=public"

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# JWT 过期时间
JWT_EXPIRES_IN="8h"

# 端口（Render 会自动设置 PORT 环境变量）
# PORT=3001

# 环境（production / development）
NODE_ENV="production"
